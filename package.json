{
  "name": "code-build-harness",
  "private": true,
  "version": "0.1.0",
  "description": "Agentic code build harness — Spec → Plan → Build → Validate → Review → Simplify → Ship with executable gates",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "lint": "biome check . && depcruise harness tests",
    "format": "biome check --write .",
    "test": "node --test tests/*.test.mjs"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.2",
    "@stryker-mutator/core": "^9.6.1",
    "dependency-cruiser": "18.1.0"
  },
  "overrides": {
    "qs": "^6.15.2"
  }
}
